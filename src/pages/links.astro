---
// src/pages/links.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const links = [
	{
		name: '剑心',
		url: 'https://blog.kiyoi.xyz/',
		desc: '剑心的博客',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`友链 - ${SITE_TITLE}`} description="我的朋友们" />
		<style>
			.links-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
				gap: 1.5em;
				padding: 1em 0;
			}
			.link-card {
				display: flex;
				align-items: center;
				gap: 1em;
				padding: 1em;
				border-radius: 8px;
				background: rgb(var(--gray-light));
				text-decoration: none;
				color: rgb(var(--gray-dark));
				transition: box-shadow 0.2s;
			}
			.link-card:hover {
				box-shadow: var(--box-shadow);
			}
			.link-card img {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				object-fit: cover;
			}
			.link-avatar-placeholder {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.2em;
				font-weight: 700;
				color: #fff;
				background: var(--accent);
				flex-shrink: 0;
			}
			.link-info h3 {
				margin: 0;
				font-size: 1em;
				color: rgb(var(--black));
			}
			.link-info p {
				margin: 0.25em 0 0;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>友链</h1>
			<p>欢迎互换友链，请通过邮件或社交媒体联系我。</p>
			<div class="links-grid">
				{links.map((link) => (
					<a class="link-card" href={link.url} target="_blank" rel="noopener">
						{link.avatar ? (
							<img src={link.avatar} alt={link.name} />
						) : (
							<div class="link-avatar-placeholder" aria-hidden="true">
								{link.name.charAt(0)}
							</div>
						)}
						<div class="link-info">
							<h3>{link.name}</h3>
							<p>{link.desc}</p>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>
