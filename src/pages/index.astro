---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<section class="intro" aria-labelledby="page-title">
				<p class="eyebrow">LEWISW.NET</p>
				<h1 id="page-title">Lewis Wang</h1>
				<p class="summary">
				Interested in domains, email, networking and self-hosting.
				</p>

				<nav class="contact-links" aria-label="Contact links">
					<a class="primary-link" href="mailto:hello@lewisw.net">hello@lewisw.net</a>
					<a href="https://github.com/xaver985" target="_blank" rel="noreferrer">
						GitHub
					</a>
				</nav>
			</section>

			<section class="about" aria-labelledby="about-title">
				<h2 id="about-title">About</h2>
				<div class="about-content">
					<p>
					Hello, I'm Lewis. I usually go by lewisw online.
					</p>
					<p>
					I'm interested in domains, email, Linux, networking and self-hosting,
					mostly through running and maintaining my own services.
					I also have a passion for the English language and Chinese culture.
					</p>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: min(100% - 2rem, 760px);
		margin: 0 auto;
		padding: 5rem 0 4rem;
	}

	section {
		padding: 3rem 0;
		border-bottom: 1px solid rgb(128 128 128 / 22%);
	}

	section:last-child {
		border-bottom: 0;
	}

	.intro {
		padding-top: 1.5rem;
	}

	.eyebrow {
		margin: 0 0 1.25rem;
		color: var(--accent, #2563eb);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0;
	}

	h1 {
		margin: 0;
		font-size: 3.5rem;
		line-height: 1.08;
		letter-spacing: 0;
	}

	.summary {
		max-width: 640px;
		margin: 1.5rem 0 0;
		color: rgb(80 80 80);
		font-size: 1.2rem;
		line-height: 1.8;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.contact-links a {
		font-weight: 600;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.3rem;
	}

	.primary-link {
		color: var(--accent, #2563eb);
	}

	h2 {
		margin: 0 0 1.5rem;
		font-size: 1.35rem;
		letter-spacing: 0;
	}

	.about-content {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
	}

	.about-content p {
		margin: 0;
		line-height: 1.9;
	}

	@media (prefers-color-scheme: dark) {
		.summary {
			color: rgb(190 190 190);
		}
	}

	@media (max-width: 640px) {
		main {
			padding-top: 3rem;
		}

		section {
			padding: 2.5rem 0;
		}

		h1 {
			font-size: 2.6rem;
		}

		.summary {
			font-size: 1.05rem;
		}

		.about-content {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}
	}
</style>
